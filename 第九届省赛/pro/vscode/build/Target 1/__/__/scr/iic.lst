 203          /**
 204           * @brief PCF8591_ADC初始化
 205           * 
 206           * @param channel：ADC转化通道
 207           *          @arg：0x00：通道0，未使用
 208           *          @arg：0x01：通道1，光敏电阻
 209           *          @arg：0x02：通道2，外接输入
 210           *          @arg：0x03：通道3，电位器
 211           * @return 无
 212           */
 213          void PCF8591_ADC_Init(unsigned char channel)
 214          {
 215   1          IIC_Start();                //启用IIC总线    
 216   1      
 217   1          IIC_SendByte(0x90);         //发送器件地址并使用写数据功能    
 218   1          IIC_WaitAck();              //等待器件应答 
 219   1      
 220   1          IIC_SendByte(channel);      //发送转换通道
 221   1          IIC_WaitAck();              //等待器件应答 
 222   1      
 223   1          IIC_Stop();                 //停止使用IIC总线 
 224   1      }
 225          
 226          /**
 227           * @brief 获取PCF8591_ADC的转换结果
 228           * @note 参考电压5V，8位数据
 229           * @param 无
 230           * @return 返回转换结果
 231           */
 232          unsigned char PCF8591_ADC_Get()
 233          {
 234   1          unsigned char date = 0;
 235   1      
 236   1          IIC_Start();              //启用IIC总线  
 237   1      
 238   1          IIC_SendByte(0x91);       //发送器件地址并使用读数据功能
 239   1          IIC_WaitAck();            //等待器件应答
C51 COMPILER V9.60.0.0   IIC                                                               01/11/2023 10:50:58 PAGE 5   

 240   1      
 241   1          date = IIC_RecByte();     //接收转换好的数据
 242   1          IIC_SendAck(1);           //发送非应答信号     
 243   1      
 244   1          IIC_Stop();               //停止使用IIC总线 
 245   1      
 246   1          return date;              //返回转换结果
 247   1      }
