 111          /**
 112           * @brief 往AT24C02写一个数据
 113           * 
 114           * @param addr 存放数据的地址，地址范围为0~255
 115           * @param date 存放的数据大小，数据范围为0~255
C51 COMPILER V9.60.0.0   IIC                                                               01/11/2023 10:50:58 PAGE 3   

 116           * @return 无
 117           */
 118          void EEPROM_Write(unsigned char addr, unsigned char date)
 119          {
 120   1          IIC_Start();                    //启用IIC总线
 121   1      
 122   1          IIC_SendByte(0xa0);             //发送器件地址并使用写数据功能
 123   1          IIC_WaitAck();                  //等待器件应答
 124   1      
 125   1          IIC_SendByte(addr);             //发送数据的地址
 126   1          IIC_WaitAck();                  //等待器件应答
 127   1      
 128   1          IIC_SendByte(date);             //发送数据
 129   1          IIC_WaitAck();                  //等待器件应答
 130   1      
 131   1          IIC_Stop();                     //停止使用IIC总线
 132   1          Delay5ms();
 133   1      }
 134          
 135          /**
 136           * @brief 从AT24C02中读一个数据
 137           * 
 138           * @param addr 所要读的数据的地址
 139           * @return 返回读出的数据
 140           */
 141          unsigned char EEPROM_Read(unsigned char addr)
 142          {
 143   1          unsigned char date = 0;
 144   1      
 145   1          IIC_Start();                        //启用IIC总线
 146   1      
 147   1          IIC_SendByte(0xa0);                 //发送器件地址并使用写数据功能
 148   1          IIC_WaitAck();                      //等待器件应答
 149   1      
 150   1          IIC_SendByte(addr);                 //发送数据的地址   
 151   1          IIC_WaitAck();                      //等待器件应答
 152   1      
 153   1          IIC_Start();                        //读写转换时，需重新启用IIC总线              
 154   1          IIC_SendByte(0xa1);                 //发送器件地址并使用读数据功能 
 155   1          IIC_WaitAck();                      //等待器件应答
 156   1      
 157   1          date = IIC_RecByte();               //接收一个字节数据
 158   1          IIC_SendAck(1);                     //发送非应答信号
 159   1      
 160   1          IIC_Stop();                         //停止使用IIC总线         
 161   1      
 162   1          return date;                        //返回读取到的数据
 163   1      }
 164          
 165          /**
 166           * @brief 连续从AT24C02读数据
 167           * 
 168           * @param addr 读数据的起始地址
 169           * @param date 读取数据存放的地址
 170           * @param num 读多少个数据
 171           * @return 无
 172           */
 173          void EEPROM_ContinuousRead(unsigned char addr, unsigned char *date, unsigned char num)
 174          {
 175   1          IIC_Start();                            //启用IIC总线
 176   1      
 177   1          IIC_SendByte(0xa0);                     //发送器件地址并使用写数据功能
C51 COMPILER V9.60.0.0   IIC                                                               01/11/2023 10:50:58 PAGE 4   

 178   1          IIC_WaitAck();                          //等待器件应答
 179   1      
 180   1          IIC_SendByte(addr);                     //发送数据的地址  
 181   1          IIC_WaitAck();                          //等待器件应答
 182   1      
 183   1          IIC_Start();                            //读写转换时，需重新启用IIC总线 
 184   1          IIC_SendByte(0xa1);                     //发送器件地址并使用读数据功能 
 185   1          IIC_WaitAck();                          //等待器件应答               
 186   1      
 187   1          while (num--)                           //控制读取多少个数据
 188   1          {
 189   2              *date++ = IIC_RecByte();            //读数据，并将指针指向下一个来接收下一个数据
 190   2              if(num != 0)                        //如果不是读取最后一个数据发送应答信号，否则发送非应答信号
 191   2              {
 192   3                  IIC_SendAck(0);                 //发送应答信号
 193   3              }
 194   2              else
 195   2              {
 196   3                  IIC_SendAck(1);                 //发送非应答信号
 197   3              }
 198   2          }   
 199   1          
 200   1          IIC_Stop();                             //停止使用IIC总线  
 201   1      }
