 227           * @return 无
 228           */
 229          void PCF8591_DAC(unsigned char date)
 230          {
 231   1          IIC_Start();                     //起始信号
 232   1      
 233   1          IIC_SendByte(0x90);              //发送器件的地址并使用写数据功能
