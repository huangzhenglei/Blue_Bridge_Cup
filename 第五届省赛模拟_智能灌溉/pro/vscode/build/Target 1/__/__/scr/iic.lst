  29          //I2C总线启动信号
  30          void IIC_Start(void)
  31          {
  32   1          /* 当SCL高电平时，SDA出现一个下降沿表示I2C总线启动信号 */
  33   1          SDA = 1;                        //将SDA初始化为高电平                
